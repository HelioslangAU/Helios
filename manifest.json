{
    "manifest_version": 3,
    "name": "Language Learning Extension",
    "version": "1.1",
    "description": "A browser extension for language learning with subtitle reading, popup dictionary, and vocab tracking",
    
    "permissions": [
      "activeTab",
      "storage",
      "scripting"
    ],
    
    "host_permissions": [
      "https://*/*",
      "http://*/*"
    ],
    
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["text-scanner.js", "content.js", "dom-text-scanner.js"],
        "css": ["popup.css"],
        "run_at": "document_end"
      }
    ],
    
    "background": {
      "service_worker": "background.js"
    },
    
    "action": {
      "default_popup": "popup.html",
      "default_title": "Language Learning Extension"
    },
    
    "web_accessible_resources": [
      {
        "resources": [
          "dictionary.json",
          "popup.css",
          "cedict_ts.u8",
          "vnedict1.txt",
          "vietnamese_dict_converted.txt"
        ],
        "matches": ["<all_urls>"]
      }
    ]
  }